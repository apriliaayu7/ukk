model Bill {
  id          Int      @id @default(autoincrement())
  title       String
  total       Int
  date        DateTime @default(now())
  status      String   // BELUM | LUNAS

  imageUrl    String?
  rawText     String?  @db.LongText

  createdById Int
  createdBy   User @relation("UserCreatedBills", fields: [createdById], references: [id])

  items        BillItem[]
  participants Participant[]
  payments     Payment[]
  summaries    UserBillSummary[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}